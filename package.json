{
  "name": "react-open-source-grid",
  "private": false,
  "version": "1.7.24",
  "type": "module",
  "description": "A high-performance React DataGrid component with advanced features like virtual scrolling, infinite scrolling, tree data, market data mode, integrated charts with context menu, and more",
  "main": "./dist/lib/index.cjs",
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "style": "./dist/lib/index.css",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.cjs"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./dist/assets/*": "./dist/assets/*",
    "./dist/assets/components/*": "./dist/assets/components/*"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "react",
    "datagrid",
    "table",
    "data-grid",
    "virtual-scroll",
    "infinite-scroll",
    "tree-data",
    "market-data",
    "typescript"
  ],
  "author": "Bhushan Poojary",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhushanpoojary/react-open-source-datagrid.git"
  },
  "bugs": {
    "url": "https://github.com/bhushanpoojary/react-open-source-datagrid/issues"
  },
  "homepage": "https://bhushanpoojary.github.io/react-open-source-datagrid",
  "scripts": {
    "build:lib": "tsup src/index.ts --format cjs,esm --out-dir dist/lib --clean && tsc -p tsconfig.build.json",
    "build": "npm run build:lib",
    "lint": "eslint .",
    "postbuild": "node ./scripts/generate-types-entry.cjs",
    "prepare": "npm run build:lib && node ./scripts/generate-types-entry.cjs && husky install"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "html-to-image": "^1.11.11",
    "recharts": "^2.10.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.2.7",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "npm run lint"
    ]
  }
}
